  "objects": [{"id": "stone_circle", "type": "examine", "x": 37, "y": 22, "text": {"irish": "Ciorcal cloch i lár na coille. Ní raibh aon chosán ag teacht anseo.", "english": "A stone circle in the middle of the wood. There was no path leading here."}}, {"id": "dark_pool_maze", "type": "examine", "x": 48, "y": 40, "text": {"irish": "Linn uisce dorcha. Tá sé ciúin go huafásach.", "english": "A dark pool of water. It is terrifyingly quiet."}}, {"id": "collapsed_altar", "type": "examine", "x": 4, "y": 49, "text": {"irish": "Altóir titithe. Tá na clocha briste. Tá rud éigin le mothú anseo fós.", "english": "A fallen altar. The stones are broken. There is something still to be felt here."}}, {"id": "ancient_tree", "type": "examine", "x": 41, "y": 6, "text": {"irish": "Crann seanda gan duilleoga. Tá cnámha timpeall air. Tá sé fós beo, ceapaim.", "english": "An ancient leafless tree. There are bones around it. I think it is still alive."}}, {"id": "true_path", "type": "examine", "x": 28, "y": 30, "text": {"irish": "Mothaím go bhfuil mé ar an gcosán ceart. Nó sin a cheapaim.", "english": "I feel I am on the right path. Or so I think."}}],
  "npcs": [],
  "introNarrative": [{"irish": "Bhí dhá bhealach isteach sa choill. Chuaigh mé ar clé.", "english": "There were two ways into the wood. I went left."}, {"irish": "B'fhéidir gur cheart dom dul ar dheis.", "english": "Perhaps I should have gone right."}, {"irish": "B'fhéidir nach raibh aon difríocht ann.", "english": "Perhaps it made no difference."}]
}
