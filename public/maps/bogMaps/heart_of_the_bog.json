  "objects": [{"id": "central_stone", "type": "examine", "x": 15, "y": 15, "text": {"irish": "An chloch. Tá tú tagtha. Tá a fhios ag an gcloch é sin freisin.", "english": "The stone. You have arrived. The stone knows that too."}}, {"id": "water_ring", "type": "examine", "x": 15, "y": 20, "text": {"irish": "An fáinne uisce. Cosaint nó príosún?", "english": "The ring of water. Protection or prison?"}}, {"id": "standing_stones_heart", "type": "examine", "x": 18, "y": 15, "text": {"irish": "Na clocha timpeall na cloiche móire. Tá siad ag caint lena chéile i gcogar.", "english": "The stones around the great stone. They are talking to each other in whispers."}}, {"id": "impossible_flowers", "type": "examine", "x": 10, "y": 10, "text": {"irish": "Bláthanna mí-nádúrtha. Tá siad ag fás as cnámha.", "english": "Unnatural flowers. They are growing from bones."}}],
  "npcs": [{"id": "cailleach", "name": "An Chailleach", "x": 15, "y": 13, "visual": {"shape": "circle", "radius": 16, "color": "0x556644"}, "dialogues": [{"irish": "'Tháinig tú sa deireadh thiar thall,' ar sise.", "english": "'You came at last,' she said."}, {"irish": "'Bhí mé anseo ó thús. Roimh an bportach. Roimh na crainn. Roimh na daoine.'", "english": "'I was here from the beginning. Before the bog. Before the trees. Before the people.'"}, {"irish": "'Cad é atá uait? Ná habair saibhreas. Ná habair grá. Abair an fhírinne.'", "english": "'What do you want? Do not say wealth. Do not say love. Say the truth.'"}]}],
  "introNarrative": [{"irish": "Bhí mé tagtha chomh fada agus ab fhéidir liom dul.", "english": "I had come as far as I could go."}, {"irish": "Ní raibh cosán ar ais ann a thuilleadh — nó ní raibh mé in ann é a fheiceáil.", "english": "There was no path back anymore — or I could no longer see it."}, {"irish": "Bhí an chloch romham. Bhí sí ag fanacht. Bhí sí i gcónaí ag fanacht.", "english": "The stone was before me. It was waiting. It had always been waiting."}],
  "entries": {"south": {"x": 15, "yFromSource": false, "y": 27}}
