  "legend": {"733": "bog", "1634": "water", "732": "island", "0": "overlay"},
  "spawns": {"player": {"x": 28, "y": 56}},
  "exits": {"south": {"tiles": [[27, 59], [28, 59], [29, 59]], "destination": "Cathair_Fola", "entryPoint": "north"}, "north": {"tiles": [[27, 0], [28, 0], [29, 0]], "destination": "Croi_na_Mona", "entryPoint": "south"}, "west": {"tiles": [[0, 29], [0, 30], [0, 31]], "destination": "Imeall_Sidhe", "entryPoint": "east"}, "east": {"tiles": [[59, 29], [59, 30], [59, 31]], "destination": "Coill_Mallaithe", "entryPoint": "north"}},
  "objects": [{"id": "island_altar", "type": "examine", "x": 28, "y": 28, "text": {"irish": "Croí an locha. Croí an phortaigh. An é seo an áit?", "english": "The heart of the lake. The heart of the bog. Is this the place?"}}, {"id": "dark_water", "type": "examine", "x": 30, "y": 35, "text": {"irish": "Tá scáthanna ag bogadh san uisce. Ní scáthanna do chuid féin iad.", "english": "Shadows are moving in the water. They are not your own shadows."}}, {"id": "stepping_stones", "type": "examine", "x": 28, "y": 42, "text": {"irish": "Na céimeanna leacacha. Leag duine éigin iad seo le go bhféadfadh duine siúl go dtí an t-oileán.", "english": "The stepping stones. Someone laid these so that a person could walk to the island."}}, {"id": "shore_bones", "type": "examine", "x": 18, "y": 32, "text": {"irish": "Cnámha ar bhruach an locha. An raibh siad ag iarraidh dul isteach nó amach?", "english": "Bones on the shore of the lake. Were they trying to get in or out?"}}],
  "npcs": [{"id": "iascaire_marbh", "name": "An tIascaire", "x": 15, "y": 35, "visual": {"shape": "circle", "radius": 16, "color": "0x334455"}, "dialogues": [{"irish": "'Tá mé ag iascaireacht anseo le céad bliain,' ar seisean.", "english": "'I have been fishing here for a hundred years,' he said."}, {"irish": "'Níor rug mé ar aon iasc. Ach coinníonn sé mé gnóthach.'", "english": "'I have caught no fish. But it keeps me busy.'"}, {"irish": "'An oileán — ná téigh ann go mbeidh tú réidh. Ní ligfidh sé amach arís thú.'", "english": "'The island — do not go there until you are ready. It will not let you out again.'"}]}],
  "introNarrative": [{"irish": "Chonaic mé an loch agus thuig mé go raibh mé ag druidim leis an gcroí.", "english": "I saw the lake and understood I was drawing near the heart."}, {"irish": "Bhí an t-uisce chomh dubh le spéir na hoíche.", "english": "The water was as black as the night sky."}, {"irish": "Agus san uisce — scáthanna. Mo scáth féin ina measc, ach níos sine.", "english": "And in the water — shadows. My own shadow among them, but older."}]
}
