  "exits": {"south": {"tiles": [[19, 39], [20, 39], [21, 39]], "destination": "Great_Open_Bog", "entryPoint": "north"}, "north": {"tiles": [[19, 0], [20, 0], [21, 0]], "destination": "Lake_Of_Shadows", "entryPoint": "south"}, "east": {"tiles": [[39, 19], [39, 20], [39, 21]], "destination": "Abandoned_Settlement", "entryPoint": "west"}, "west": {"tiles": [[0, 19], [0, 20], [0, 21]], "destination": "Cursed_Wood", "entryPoint": "east"}},
  "objects": [{"id": "altar_stone", "type": "examine", "x": 20, "y": 20, "text": {"irish": "Cloch altóra. Tá smál fola uirthi nach féidir a ghlanadh.", "english": "An altar stone. It bears a stain of blood that cannot be cleaned."}}, {"id": "bog_warrior", "type": "examine", "x": 5, "y": 5, "text": {"irish": "Laoch an phortaigh. Tá a arm fós ina láimh tar éis míle bliain.", "english": "A bog warrior. His weapon is still in his hand after a thousand years."}}, {"id": "fort_gate", "type": "examine", "x": 20, "y": 32, "text": {"irish": "Geata na cathrach. Cé a throid ar son na háite seo?", "english": "The fortress gate. Who fought for this place?"}}, {"id": "ravens", "type": "examine", "x": 15, "y": 10, "text": {"irish": "Tá na fiach dubha ag faire ort ón mballa.", "english": "The ravens are watching you from the wall."}}],
  "npcs": [{"id": "fear_dearg", "name": "Fear Dearg", "x": 25, "y": 25, "visual": {"shape": "circle", "radius": 16, "color": "0x990000"}, "dialogues": [{"irish": "'Fáilte go Cathair Fola,' ar seisean. 'Tá tú mall.'", "english": "'Welcome to the Fortress of Blood,' he said. 'You are late.'"}, {"irish": "'Throid mo mhuintir ar feadh trí lá agus trí oíche. Níor bhain siad é.'", "english": "'My people fought for three days and three nights. They did not win it.'"}, {"irish": "'Ach táimid fós anseo. An portach ní ligann sé dúinn imeacht.'", "english": "'But we are still here. The bog will not let us leave.'"}]}],
  "introNarrative": [{"irish": "Chonaic mé na ballaí ó i bhfad. Bhí siad ag éirí as an bportach", "english": "I saw the walls from far away. They rose from the bog"}, {"irish": "cosúil le cnámha mil bliain d'aois.", "english": "like bones a thousand years old."}, {"irish": "Bhí boladh na fola fós san aer. Nó b'fhéidir gurbh é boladh an phortaigh é.", "english": "The smell of blood was still in the air. Or perhaps it was the smell of the bog."}]
