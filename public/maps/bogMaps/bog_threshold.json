  "objects": [{"id": "skull_north", "type": "examine", "x": 14, "y": 12, "text": {"irish": "Cloigeann mór. Cuireann sé faitíos ort. Tá súile air nach bhfuil ann.", "english": "A great skull. It unsettles you. It has eyes that are not there."}}, {"id": "skull_south", "type": "examine", "x": 14, "y": 16, "text": {"irish": "An dara cloigeann. Tá siad ag féachaint ar a chéile thar an gconair.", "english": "The second skull. They are looking at each other across the path."}}, {"id": "path_end", "type": "examine", "x": 6, "y": 14, "text": {"irish": "Tá an cosán ag imeacht faoin bportach. Níl aon slí ar ais feicthe agam.", "english": "The path disappears into the bog. I can see no way back."}}, {"id": "standing_stone", "type": "examine", "x": 10, "y": 14, "text": {"irish": "Cloch ard. Tá sí níos sine ná cuimhne.", "english": "A tall stone. It is older than memory."}}],
  "npcs": [],
  "introNarrative": [{"irish": "Sheas mé ag an teorainn.", "english": "I stood at the boundary."}, {"irish": "Ar thaobh amháin — an domhan a bhí ar eolas agam. Ar an taobh eile — an portach.", "english": "On one side — the world I knew. On the other side — the bog."}, {"irish": "Bhí na cloigne ag faire. Ní dúirt siad tada.", "english": "The skulls were watching. They said nothing."}],
