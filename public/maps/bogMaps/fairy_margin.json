  "objects": [{"id": "fairy_mound", "type": "examine", "x": 15, "y": 15, "text": {"irish": "Cnoc sí. Tá teas ag teacht as an talamh. Cloiseann tú ceol i bhfad i gcéin.", "english": "A fairy mound. Heat is rising from the ground. You hear music from far away."}}, {"id": "standing_stone_ring", "type": "examine", "x": 15, "y": 7, "text": {"irish": "Na clocha ina gciorcal. Tá siad níos sine ná cuimhne na ndaoine.", "english": "The stones in their circle. They are older than the memory of people."}}, {"id": "strange_flowers", "type": "examine", "x": 20, "y": 12, "text": {"irish": "Bláthanna nach bhfaca tú riamh roimhe. Tá siad ag canadh go ciúin.", "english": "Flowers you have never seen before. They are singing quietly."}}, {"id": "mound_entrance", "type": "examine", "x": 15, "y": 14, "text": {"irish": "An bhfuil doras anseo? Mothaíonn tú rud éigin ag brú ón taobh istigh.", "english": "Is there a door here? You feel something pushing from the inside."}}],
  "npcs": [{"id": "sí_bean", "name": "Bean an Chnuic", "x": 15, "y": 12, "visual": {"shape": "circle", "radius": 16, "color": "0xaaffaa"}, "dialogues": [{"irish": "'Ná bain leis an gcnoc,' ar sise, gan a béal a oscailt.", "english": "'Do not touch the mound,' she said, without opening her mouth."}, {"irish": "'Tá ár gcuid féin ann. Tá bhur gcuid féin in áit eile.'", "english": "'What is ours is there. What is yours is elsewhere.'"}, {"irish": "'Ach más mian leat, féadfaidh tú éisteacht.'", "english": "'But if you wish, you may listen.'"}]}],
  "introNarrative": [{"irish": "Bhí an t-aer difriúil anseo. Níos teo. Níos beo.", "english": "The air was different here. Warmer. More alive."}, {"irish": "Bhí bláthanna ag fás nach raibh aon ainm Gaeilge orthu.", "english": "Flowers were growing that had no Irish name."}, {"irish": "Bhí a fhios agam nach raibh mé sa saol seo go hiomlán a thuilleadh.", "english": "I knew I was no longer entirely in this world."}]
}
