  "objects": [{"id": "puca_cave", "type": "examine", "x": 35, "y": 12, "text": {"irish": "Uaimh an phúca. Tá dorchadas iomlán istigh ann. Cloiseann tú anáil.", "english": "The púca's cave. There is total darkness inside. You can hear breathing."}}, {"id": "hanging_webs", "type": "examine", "x": 8, "y": 6, "text": {"irish": "Líonta damháin alla. Ró-mhór. Ró-láidir. Ná bain leo.", "english": "Spider webs. Too large. Too strong. Do not touch them."}}, {"id": "wrong_trees", "type": "examine", "x": 15, "y": 8, "text": {"irish": "Na crainn seo — níl siad ceart. Tá siad ag breathnú ort.", "english": "These trees — they are not right. They are watching you."}}, {"id": "skull_warning", "type": "examine", "x": 35, "y": 10, "text": {"irish": "Cé a chuir na cloigne seo anseo? Rabhadh nó cuireadh?", "english": "Who placed these skulls here? A warning or an invitation?"}}],
  "npcs": [{"id": "puca", "name": "An Púca", "x": 37, "y": 12, "visual": {"shape": "circle", "radius": 16, "color": "0x222200"}, "dialogues": [{"irish": "'Tar isteach, tar isteach,' ar seisean. 'Tá sé te anseo istigh.'", "english": "'Come in, come in,' he said. 'It is warm in here.'"}, {"irish": "'Tá mé ag fanacht leat le fada an lá.'", "english": "'I have been waiting for you for a long time.'"}, {"irish": "'Nó b'fhéidir nach raibh. Tá am difriúil san uaimh.'", "english": "'Or perhaps not. Time is different in the cave.'"}]}],
  "introNarrative": [{"irish": "Tháinig mé isteach sa choill agus d'imigh an solas.", "english": "I entered the wood and the light disappeared."}, {"irish": "Ní raibh na crainn mar chrainn eile. Bhí rud éigin iontu.", "english": "The trees were not like other trees. There was something in them."}, {"irish": "Agus bhí boladh ann — créafóg agus rud eile nach raibh ainm agam air.", "english": "And there was a smell — earth and something else I had no name for."}]
}
