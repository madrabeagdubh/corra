  "objects": [{"id": "bog_body", "type": "examine", "x": 15, "y": 18, "text": {"irish": "Corp fir sa phortach. Tá sé ann le céadta bliain. Tá cuma shuaimhneach air.", "english": "A man's body in the bog. He has been here for hundreds of years. He looks peaceful."}}, {"id": "standing_stone", "type": "examine", "x": 10, "y": 14, "text": {"irish": "Cloch ard chaol. Tá rúin gearrtha inti nach dtuigeann tú.", "english": "A tall thin stone. Runes are carved into it that you cannot understand."}}, {"id": "lost_path", "type": "examine", "x": 30, "y": 20, "text": {"irish": "An raibh cosán anseo uair amháin? Tá an portach ag ithe an talaimh.", "english": "Was there a path here once? The bog is consuming the land."}}, {"id": "dark_pool", "type": "examine", "x": 27, "y": 10, "text": {"irish": "Linn dhorcha gan tóin. Ná féach isteach inti.", "english": "A dark pool with no bottom. Do not look into it."}}],
