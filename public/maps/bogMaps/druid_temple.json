  "objects": [{"id": "temple_altar", "type": "examine", "x": 15, "y": 12, "text": {"irish": "Cloch altóra sa teampall. Tá rud éigin fágtha uirthi — ní fheicim cad é.", "english": "An altar stone in the temple. Something has been left on it — I cannot see what."}}, {"id": "temple_entrance", "type": "examine", "x": 15, "y": 15, "text": {"irish": "Tairseach an teampaill. Mothaím go bhfuil mé ag dul isteach in áit naofa.", "english": "The temple threshold. I feel I am entering a sacred place."}}, {"id": "small_ruin", "type": "examine", "x": 22, "y": 10, "text": {"irish": "Foirgneamh beag eile. Níos sine ná an teampall. Tá staighre síos ann.", "english": "Another small building. Older than the temple. There are stairs going down."}}, {"id": "stairs_down", "type": "examine", "x": 22, "y": 10, "text": {"irish": "Staighre síos sa dorchadas. Ní fheicim deireadh leis.", "english": "Stairs down into the darkness. I cannot see the end of them."}}, {"id": "cliff_edge", "type": "examine", "x": 15, "y": 5, "text": {"irish": "Aille ard. Tá talamh álainn thuas ansin nach féidir liom a bhaint amach.", "english": "A high cliff. There is beautiful land up there that I cannot reach."}}, {"id": "lake_shore", "type": "examine", "x": 15, "y": 22, "text": {"irish": "Bruach an locha. Tá na clocha leacacha ag dul trasna. Cá bhfuil siad ag dul?", "english": "The lake shore. The stepping stones cross over. Where do they go?"}}],
  "npcs": [{"id": "druid_conall", "name": "Conall", "x": 15, "y": 11, "visual": {"shape": "circle", "radius": 16, "color": "0x336644"}, "dialogues": [{"irish": "'Tháinig tú,' ar seisean. 'Bhí a fhios agam go dtiocfá.'", "english": "'You came,' he said. 'I knew you would come.'"}, {"irish": "'Tá an portach ag éisteacht leat. Bí cúramach cad a deir tú os ard.'", "english": "'The bog is listening to you. Be careful what you say aloud.'"}, {"irish": "'Tá cosán amháin chun tosaigh. Ní fheicfidh tú é go mbeidh tú réidh.'", "english": "'There is one path forward. You will not see it until you are ready.'"}]}],
  "introNarrative": [{"irish": "Fuair mé an teampall sa deireadh.", "english": "I found the temple at last."}, {"irish": "Bhí sé i bhfolach sa choill — nó b'fhéidir gur oscail an choill dom é.", "english": "It was hidden in the wood — or perhaps the wood opened it for me."}, {"irish": "Bhí fear ann ag fanacht. Bhí a fhios aige m'ainm.", "english": "There was a man there waiting. He knew my name."}]
}
