  "objects": [{"id": "broken_door", "type": "examine", "x": 15, "y": 13, "text": {"irish": "Doras briste. Bhris duine éigin isteach — nó amach.", "english": "A broken door. Someone broke in — or out."}}, {"id": "throne", "type": "examine", "x": 23, "y": 21, "text": {"irish": "Cathaoir ríoga sa bhfoirgneamh thréigthe. Cé a shuigh anseo?", "english": "A royal chair in the abandoned building. Who sat here?"}}, {"id": "dark_book", "type": "examine", "x": 14, "y": 10, "text": {"irish": "Leabhar dorcha. Tá na focail ag bogadh ar an leathanach.", "english": "A dark book. The words are moving on the page."}}, {"id": "well", "type": "examine", "x": 20, "y": 18, "text": {"irish": "Tobar tirim. Tá boladh aisteach ag teacht as.", "english": "A dry well. A strange smell is coming from it."}}],
  "npcs": [{"id": "bean_si_silent", "name": "?", "x": 16, "y": 16, "visual": {"shape": "circle", "radius": 16, "color": "0xccccff"}, "dialogues": [{"irish": "(Níl aon fhuaim ann. Ach tá sí ag féachaint ort.)", "english": "(There is no sound. But she is looking at you.)"}, {"irish": "(Síneann sí a méar i dtreo an iarthair.)", "english": "(She extends her finger toward the west.)"}]}],
  "introNarrative": [{"irish": "Bhí baile anseo uair amháin. Tá a fhios agam é sin.", "english": "There was a village here once. I know that much."}, {"irish": "Ach d'imigh na daoine — in aon oíche amháin, de réir cosúlachta.", "english": "But the people left — in a single night, it seems."}, {"irish": "Fágadh gach rud ina ndiaidh. Gach rud ach iad féin.", "english": "Everything was left behind. Everything except themselves."}]
