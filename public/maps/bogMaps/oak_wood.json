  "objects": [{"id": "forester_table", "type": "examine", "x": 53, "y": 6, "text": {"irish": "Bord le páipéir. Léarscáileanna. Nótaí i scríbhneoireacht nach n-aithníonn tú.", "english": "A table with papers. Maps. Notes in a handwriting you don't recognise."}}, {"id": "weapons_rack", "type": "examine", "x": 55, "y": 5, "text": {"irish": "Raca arm folamh. Bhí arm anseo tráth. Tá siad imithe anois.", "english": "An empty weapons rack. There were weapons here once. They are gone now."}}, {"id": "fallen_oak", "type": "examine", "x": 30, "y": 5, "text": {"irish": "Crann darach leagtha. Bhí sé mór tráth. Cad a leag é?", "english": "A fallen oak tree. It was great once. What felled it?"}}, {"id": "fairy_ring", "type": "examine", "x": 24, "y": 45, "text": {"irish": "Fáinne sí. Ná seas istigh ann mura bhfuil tú réidh le himeacht.", "english": "A fairy ring. Do not stand inside it unless you are ready to leave."}}, {"id": "dark_pond", "type": "examine", "x": 10, "y": 13, "text": {"irish": "Linn dorcha. Tá rud éigin ag bogadh san uisce nach iasc é.", "english": "A dark pond. Something is moving in the water that is not a fish."}}, {"id": "changing_trees", "type": "examine", "x": 15, "y": 14, "text": {"irish": "Tá na crainn ag athrú. Níl mé cinnte cathain a thosaigh sé.", "english": "The trees are changing. I am not sure when it started."}}],
  "npcs": [],
  "introNarrative": [{"irish": "Shiúil mé isteach sa choill darach agus bhí solas ann.", "english": "I walked into the oak wood and there was light."}, {"irish": "Bláthanna. Éin. An saol ag leanúint ar aghaidh gan buaireamh.", "english": "Flowers. Birds. Life continuing without worry."}, {"irish": "Ach thiar, i gcoinne na gaoithe, bhí boladh éigin nár thuig mé fós.", "english": "But westward, against the wind, there was a smell I did not yet understand."}]
